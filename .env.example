# Copy to .env and fill in. .env is git-ignored.

# ===== OpenAI（可选） =====
OPENAI_API_KEY=

# ===== Anthropic Claude（可选） =====
ANTHROPIC_API_KEY=

# ===== Google Gemini（可选） =====
GOOGLE_API_KEY=

# ===== 智谱 GLM（可选） =====
ZHIPU_API_KEY=

# ===== 本地 vLLM 服务（推荐） =====
QWEN_VL_BASE_URL=http://localhost:8000/v1
QWEN_VL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# ===== AirSim ip 与端口（默认本机） =====
AIRSIM_IP=127.0.0.1
AIRSIM_RPC_PORT=41451
